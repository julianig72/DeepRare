##FILTER=<ID=LowReadDepth,Description="'DP < 16'">
##FILTER=<ID=LowReadPosRankSum,Description="'ReadPosRankSum < -8.0'">
##FILTER=<ID=StrandBias,Description="'FS > 60.0'">
